{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "光鸭文件夹同步",
  "version": "0.1.13",
  "identifier": "com.hackguangya.folder-sync",
  "build": {
    "beforeDevCommand": "pnpm ui:dev",
    "beforeBuildCommand": "pnpm ui:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "光鸭文件夹同步",
        "width": 1040,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
